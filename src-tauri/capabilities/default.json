{
  "$schema": "../gen/schemas/desktop-schema.json",
  "capabilities": [
    {
      "identifier": "default-desktop",
      "description": "Desktop capability for the main window",
      "windows": ["main"],
      "platforms": ["macOS", "windows", "linux"],
      "permissions": [
        "core:default",
        "opener:default",
        "updater:default",
        "process:default"
      ]
    },
    {
      "identifier": "default-mobile",
      "description": "Mobile capability for the main window",
      "windows": ["main"],
      "platforms": ["android", "iOS"],
      "permissions": [
        "core:default",
        "opener:default",
        "process:default"
      ]
    }
  ]
}
