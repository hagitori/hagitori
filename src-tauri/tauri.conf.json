{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hagitori",
  "version": "0.0.1-beta",
  "identifier": "com.hagitori.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Hagitori",
        "width": 1200,
        "height": 800
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": [
            "$APPCACHE/covers/**"
          ]
        }
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEMxMzMyQkM3REY4NUVDMDkKUldRSjdJWGZ4eXN6d2NDT2EyMWRWTi9vY05HaFlqb2lGckpGeU1WSy9XMmt3N1A3bHZXUnduckgK",
      "endpoints": [
        "https://github.com/hagitori/hagitori/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "copyright": "© Hagitori",
    "targets": [
      "nsis",
      "deb",
      "rpm",
      "appimage"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "headerImage": "icons/nsis-header.bmp",
        "sidebarImage": "icons/nsis-sidebar.bmp",
        "displayLanguageSelector": true,
        "languages": [
          "English",
          "PortugueseBR"
        ],
        "installerHooks": "nsis/hooks.nsh"
      }
    }
  }
}
